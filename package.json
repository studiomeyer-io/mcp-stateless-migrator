{
  "name": "mcp-stateless-migrator",
  "version": "0.1.2",
  "description": "CLI tool that scans MCP-server codebases for incompatibilities with MCP-Spec 2026-07-28 RC (Stateless Core, mandatory headers, deprecations, error-code shift, OAuth hardening) and applies safe AST-rewrites where mechanically possible.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-stateless-migrator": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "migration",
    "codemod",
    "stateless",
    "spec-2026-07-28",
    "ast-rewrite",
    "ast",
    "refactor",
    "ts-morph",
    "cli"
  ],
  "author": "Matthias Meyer (StudioMeyer)",
  "license": "MIT",
  "homepage": "https://github.com/studiomeyer-io/mcp-stateless-migrator",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/studiomeyer-io/mcp-stateless-migrator.git"
  },
  "bugs": {
    "url": "https://github.com/studiomeyer-io/mcp-stateless-migrator/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "diff": "^9.0.0",
    "fast-glob": "^3.3.3",
    "ts-morph": "^28.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
